{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_build/|assets/|favicon\\.ico|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/api/index"
    }
  ]
}
